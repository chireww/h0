ion (_, result) {","                jsonData = result;","            });","          }","          let value = JSONPath({","            json: jsonData,","            path: expression,","            wrap: false","          });","","          if (false && undefined !== undefined) {","            if (Array.isArray(value)) {","              value = Number(undefined) >= 0 ? value[undefined] : value[value.length + Number(undefined)];","            } else {","              value = undefined;","            }","          }","","          ","          ","          ","        if(value === null){","          pm.expect(value).to.not.be.null","        } else if(value === undefined) {","          pm.expect(value).to.not.be.undefined","        } else {","          pm.expect(String(value)).to.not.be.empty","        }","      ","          done();","        } catch (err) {","          done(err);","        }","      });","    } catch(e) {","      setImmediate(() => { throw e });","    }","  })();","      "]}},{"listen":"test","script":{"id":"postProcessors.1.customScript","type":"text/javascript","exec":["","        if (JSON.setEnableBigInt) {","          JSON.setEnableBigInt(undefined);","        }","        // 从接口响应中提取token并设为环境变量","var responseData = pm.response.json();","var token = responseData.data.token;","pm.environment.set(\"Bearer_token\", \"Bearer \" + token);","      "]}},{"listen":"test","script":{"id":"postProcessors.2.commonScript","type":"text/javascript","exec":["","        if (JSON.setEnableBigInt) {","          JSON.setEnableBigInt(undefined);","        }","        // 设置要遍历的目录路径","const targetDirectory = pm.environment.get(\"file_dir\"); ","","async function getAllFilePaths() {","    try {","        // 调用外部Python程序获取文件列表[5](@ref)","        const result = await pm.executeAsync(\"get_files_info.py\", [targetDirectory]);","    ","        ","        // 解析返回的JSON数据","        const data = JSON.parse(result);","        ","        if (data.file_count) {","            const fileList = data.file_full_paths.filter(filePath => !filePath.endsWith('.DS_Store'));","            const fileCount = data.file_count;","","            // 将完整文件列表存储到环境变量","            pm.variables.set(\"all_file_paths\", JSON.stringify(fileList));","            ","            return fileList;","        } else {","            console.error(\"获取文件列表失败:\", data.error);","            return [];","        }","    } catch (error) {","        console.error(\"执行外部程序时出错:\", error.message);","        return [];","    }","}","","// 执行文件获取","getAllFilePaths();","      "]}}],"responseDefinition":{"validateDeletedResponse":false},"requestDefinition":{"jsonSchema":{"type":"object","properties":{"email":{"type":"string"},"password":{"type":"string"}},"required":["email","password"]}},"overrideRequesterOptions":{"strictSSL":false},"metaInfo":{"blockId":"836ac25e-8125-4977-a491-bd00cb68252c","id":"836ac25e-8125-4977-a491-bd00cb68252c","type":"customHttp","name":"登录","projectId":7611479,"relatedId":7706948,"environmentId":41149538,"blockNumber":1,"httpApiId":2999787,"httpApiCaseId":2999787,"httpApiName":"登录","httpApiPath":"/auth/email/login","httpApiMethod":"post","httpApiCaseName":"登录","serverId":"default"},"type":"http","protocolProfileBehavior":{"useWhatWGUrlParser":false,"disableUrlEncoding":false,"disabledSystemHeaders":{},"disableCookies":false}},{"id":"ff37cd1f-e03d-4362-9124-c749fa7b94e1__forEach","type":"group","metaInfo":{"id":"ff37cd1f-e03d-4362-9124-c749fa7b94e1__forEach","type":"group","scopeType":"start","scopeEndId":"d9146eba-1192-58c4-9bad-a602046bad8e__forEach","extraData":{"arrayVariable":"all_file_paths"}}},{"id":"ff37cd1f-e03d-4362-9124-c749fa7b94e1","type":"forEach","number":8,"parameters":{"array":"{{all_file_paths}}","onError":"break","disableOnError":false},"disable":false,"metaInfo":{"id":"ff37cd1f-e03d-4362-9124-c749fa7b94e1","type":"forEach","number":8,"scopeType":"start","scopeEndId":"d9146eba-1192-58c4-9bad-a602046bad8e","index":1,"arrayVariable":"all_file_paths","onError":"break","disableOnError":false,"extracts":[{"expression":"$.8.element","paths":["$","8","element"]}]}},{"id":"eab2bdc9-197b-4be6-8f7c-6f48844ec915","name":"上传审核文件","request":{"url":{"protocol":"https","path":["api","oss","upload"],"host":["dev-api-v3-az-mlr","nullht","com"],"query":[],"variable":[]},"header":[{"key":"Authorization","value":"{{Bearer_token}}"},{"key":"User-Agent","value":"Apifox/1.0.0 (https://apifox.com)"}],"method":"POST","baseUrl":"https://dev-api-v3-az-mlr.nullht.com/api","body":{"mode":"formdata","formdata":[{"key":"file","type":"file","src":"{{$.8.element}}"}]},"auth":{"type":"noauth","noauth":[]},"type":"http"},"response":[],"event":[{"listen":"test","script":{"id":"postProcessors.0.extractor","type":"text/javascript","exec":["","        if (JSON.setEnableBigInt) {","          JSON.setEnableBigInt(undefined);","        }","        ","      async function ____replaceIn(value) {","        if (typeof pm.variables.replaceInAsync === 'function') {","          return await pm.variables.replaceInAsync(value);","        }","        return pm.variables.replaceIn(value);","      };","      ;(async () => {","        try{","          ","          const expression = await ____replaceIn(`$.data`);","          const JSONPath = require('jsonpath-plus').JSONPath;","          const jsonData = pm.response.json();","          let value = JSONPath({","            json: jsonData,","            path: expression,","            wrap: false","          });","","","          if (false && undefined !== undefined) {","            if (Array.isArray(value)) {","              value = Number(undefined) >= 0 ? value[undefined] : value[value.length + Number(undefined)];","            } else {","              value = undefined;","            }","          }","          ","          ","        switch (typeof value) {","          case 'object':","            value = JSON.stringify(value);","            break;","          default:","            value = String(value);","            break;","        }","      ","          const formattedName = await ____replaceIn(`file_id`);pm.variables.set(formattedName, value);console.log('___label_placeholder__processor___', '已设置临时变量【' + formattedName + '】，值为' + ' ' + '【' + value + '】')","        } catch(e) {","          e.message = `提取变量【file_id】出错: ` + e.message;","          setImmediate(() => { throw e });","        }","      })();","      "]}},{"listen":"test","script":{"id":"postProcessors.1.httpApiExtractor","type":"text/javascript","exec":["","        if (JSON.setEnableBigInt) {","          JSON.setEnableBigInt(undefined);","        }","        let requestJSON, responseJSON;","      const extracts = [{\"expression\":\"$.2.response.body.data\",\"paths\":[\"$\",\"2\",\"response\",\"body\",\"data\"]}];","      function getJSONPath(paths, index) {","        const path = paths.slice(index).join('.');","        const root = path[0] === '[' ? '$' : '$.';","        return root + path;","      }","      function extractJSON(json, path) {","        const JSONPath = require('jsonpath-plus').JSONPath;","        return JSONPath({ json, path, wrap: false });","      }","      function getValue(propertyList, targetKey, keyName) {","        keyName = keyName || 'key';","        if (propertyList.filter) {","          const values = propertyList.filter(item => item[keyName] === targetKey);","          if (values.length === 1) {","            return values[0].value;","          } else if (values.length > 1) {","            return values.map(item => item.value);","          }","        } else if (propertyList.get) {","          return propertyList.get(targetKey);","        }","        return undefined;","      }","      ","      for (const { expression, paths } of extracts) {","        let value;","        try {","          if (paths[2] === 'request') {","            if (paths[3] === 'url') {","              value = pm.request.url.toString();","            } else if (paths[3] === 'headers' || paths[3] === 'header') {","              value = getValue(pm.request.headers, paths[4]);","            } else if (paths[3] === 'pathParams' || paths[3] === 'pathParam') {","              value = getValue(pm.request.url.variables, paths[4]);","            } else if (paths[3] === 'query' || paths[3] === 'params' || paths[3] === 'param') {","              value = getValue(pm.request.url.query, paths[4]);","            } else if (paths[3] === 'body') {","              const body = pm.request.body;","              const bodyData = body[body.mode];","              if (typeof bodyData === \"string\") {","                if (!requestJSON) {","                  requestJSON = JSON.parse(bodyData);","                }","                value = extractJSON(requestJSON, getJSONPath(paths, 4));","              } else {","                value = getValue(bodyData, paths[4]);","                if (value === undefined) {","                  value = extractJSON(body, getJSONPath(paths, 4));","                }","              }","            } else if (paths[3] === 'cookies' || paths[3] === 'cookie') {","              const cookies = pm.request.headers.get('Cookie') || '';","              if (paths[4]) {","                cookies.split(';').find(cookie => {","                  const splitIndex = cookie.indexOf('=');","                  const cookieKey = cookie.slice(0, splitIndex);","                  const cookieValue = cookie.slice(splitIndex + 1);","                  if (cookieKey === paths[4]) {","                    value = cookieValue;","                    return true;","                  }","                })","              } else {","                value = cookies;","              }","            } else {","              value = extractJSON(pm.request, getJSONPath(paths, 3));","            }","          } else if (paths[2] === 'response') {","            if (paths[3] === 'headers' || paths[3] === 'header') {","              value = getValue(pm.response.headers, paths[4]);","            } else if (paths[3] === 'cookies' || paths[3] === 'cookie') {","              value = getValue(pm.response.cookies, paths[4], 'name');","            } else if (paths[3] === 'body') {","              try {","                if (!responseJSON) {","                  responseJSON = pm.response.json();","                }","                value = extractJSON(responseJSON, getJSONPath(paths, 4));","              } catch (e) {","                console.log('ParseJsonFailed', e)","                value = pm.response.text();","              }","","            } else {","              value = extractJSON(pm.response, getJSONPath(paths, 3));","            }","          } ","","          if (value === null) {","            value = 'null'","          }","","          pm.variables.set(expression, value);","        } catch (e) {","          console.log('httpApiExtractorScriptError', e)","        }","      }","      "]}}],"responseDefinition":{"validateDeletedResponse":false},"requestDefinition":{"jsonSchema":{}},"overrideRequesterOptions":{"strictSSL":false},"metaInfo":{"blockId":"eab2bdc9-197b-4be6-8f7c-6f48844ec915","id":"eab2bdc9-197b-4be6-8f7c-6f48844ec915","type":"customHttp","name":"上传审核文件","projectId":7611479,"relatedId":7706948,"environmentId":41149538,"blockNumber":2,"httpApiId":2999789,"httpApiCaseId":2999789,"httpApiName":"上传审核文件","httpApiPath":"/oss/upload","httpApiMethod":"post","httpApiCaseName":"上传审核文件","serverId":"default"},"type":"http","protocolProfileBehavior":{"useWhatWGUrlParser":false,"disableUrlEncoding":false,"disabledSystemHeaders":{},"disableCookies":false}},{"id":"c7c80f2f-fd44-4eef-8278-5995d7f34310","type":"if","metaInfo":{"id":"c7c80f2f-fd44-4eef-8278-5995d7f34310","type":"if","scopeType":"start","scopeEndId":"c0334231-a8d9-54ee-954e-2663a921e447","parameters":{"keyVariable":"{{$.2.response.body.data}}","operator":"isNotEmpty","valueVariable":"true"},"events":[{"description":"{{$.2.response.body.data}} isNotEmpty true","listen":"test","script":{"e