{"info":{"_postman_id":"4e481f28-937b-4826-86d3-2a74249cd975","name":"文献检索","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"item":[{"name":"初始化文献检索会话","request":{"method":"POST","url":"{{BASE_URL}}/api/retrieval/init","header":[{"key":"Authorization","value":"{{Authorization}}"},{"key":"Cookie","value":"KB_SESSION_ID={{KB_SESSION_ID}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n    \"application_config_id\": \"{{app_id}}\",\n    \"question\": \"{{question}}\",\n    \"scopes\": [\n        \"PAPER\",\n        \"PAPER_CN\",\n        \"GUIDE\"\n    ]\n}","options":{"raw":{"language":"json"}}}},"events":[],"protocolProfileBehavior":{"disableBodyPruning":true}},{"name":"流式获取knows完整证据列表-含摘要","request":{"method":"POST","url":"{{BASE_URL}}/api/knows/recall/stream","header":[{"key":"Authorization","value":["{{Authorization}}"]},{"key":"Cookie","value":"KB_SESSION_ID={{KB_SESSION_ID}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n    \"retrieval_id\": \"{{$.1.response.body.data.retrieval_id}}\",\n    \"application_config_id\": {{app_id}}\n}","options":{"raw":{"language":"json"}}}},"events":[{"listen":"test","script":{"exec":["\n        if (JSON.setEnableBigInt) {\n          JSON.setEnableBigInt(undefined);\n        }\n        // 1. 获取响应文本并按行分割\r\nconst lines = pm.response.text().split('\\n');\r\n\r\n// 2. 遍历每行，提取第一个含 evidence_id 和 question_id 的 data 字段\r\nfor (const line of lines) {\r\n  if (line.startsWith('data: ')) {\r\n    try {\r\n      const data = JSON.parse(line.slice(6));\r\n      if (data.evidence_id && data.question_id) {\r\n        // 提取目标字段\r\n        const evidenceId = data.evidence_id;\r\n        const questionId = data.question_id;\r\n\r\n        // 打印结果（调试用）\r\n        console.log('提取到 evidence_id:', evidenceId);\r\n        console.log('提取到 question_id:', questionId);\r\n\r\n        // 保存到变量（供后续步骤引用）\r\n        pm.variables.set('evidenceId', evidenceId);\r\n        pm.variables.set('questionId', questionId);\r\n        \r\n        break; // 提取后退出循环\r\n      }\r\n    } catch (e) {\r\n      // 忽略非JSON行\r\n    }\r\n  }\r\n}\n      "],"type":"text/javascript"}}],"protocolProfileBehavior":{"disableBodyPruning":true}},{"name":"paper文献详情","request":{"method":"POST","url":"{{BASE_URL}}/api/knows/paper/details","header":[{"key":"Authorization","value":"{{Authorization}}"},{"key":"Cookie","value":"KB_SESSION_ID={{KB_SESSION_ID}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n    \"evidence_id\": \"{{evidenceId}}\"\n}","options":{"raw":{"language":"json"}}}},"events":[],"protocolProfileBehavior":{"disableBodyPruning":true}},{"name":"流式召回knows答案","request":{"method":"POST","url":"{{BASE_URL}}/api/knows/scene_summary","header":[{"key":"Authorization","value":"{{Authorization}}"},{"key":"Cookie","value":"KB_SESSION_ID={{KB_SESSION_ID}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n    \"question_id\": \"{{questionId}}\",\n    \"answer_type\": \"{{answer_type}}\"\n}","options":{"raw":{"language":"json"}}}},"events":[],"protocolProfileBehavior":{"disableBodyPruning":true}},{"name":"历史问答记录","request":{"method":"POST","url":"{{BASE_URL}}/api/retrieval/history","header":[{"key":"Authorization","value":"{{Authorization}}"},{"key":"Cookie","value":"KB_SESSION_ID={{KB_SESSION_ID}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n    \"application_config_id\": \"123\",\n    \"page_num\": ,\n    \"page_size\": \n}","options":{"raw":{"language":"json"}}}},"events":[],"protocolProfileBehavior":{"disableBodyPruning":true}}],"variable":[{"key":"Authorization","value":"Bearer {{Bearer_token}}","type":"string"},{"key":"KB_SESSION_ID","value":"w1XImv9JEvykRAtwQNBjzC","type":"string"},{"key":"ASSERTION_RESULT","value":"","type":"string"},{"key":"BASE_URL","value":"https://sanofi-yzj-kb-api.nullht.com","type":"string"}]}